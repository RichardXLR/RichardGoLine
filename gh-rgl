#!/usr/bin/env bash
# gh-rgl - CLI wrapper para RichardGoLine GitHub Actions
# Uso: gh-rgl "https://youtube.com/watch?v=..." [opções]

set -euo pipefail

# Config
REPO="${RGL_REPO:-$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null)}"
WORKFLOW="download.yml"
ARTIFACT_DIR="${RGL_DIR:-$HOME/Downloads/RichardGoLine}"

# Cores
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

log() { echo -e "${BLUE}[gh-rgl]${NC} $*"; }
ok() { echo -e "${GREEN}[✓]${NC} $*"; }
warn() { echo -e "${YELLOW}[!]${NC} $*"; }
err() { echo -e "${RED}[✗]${NC} $*"; }

usage() {
  cat <<EOF
${CYAN}gh-rgl${NC} - RichardGoLine via GitHub Actions (grátis)

${YELLOW}Uso:${NC}
  gh-rgl "URL" [opções]

${YELLOW}Opções:${NC}
  -m, --mode MODE          Modo: best, audio, video, 1080p, 720p, 4k, custom
  -f, --format FORMAT      Format ID (ex: 313+251) - requer --mode custom
  -a, --audio-fmt FORMAT   Formato áudio: opus, mp3, flac, m4a, wav (padrão: opus)
  -q, --audio-quality Q    Qualidade 0-10 (padrão: 0)
  -s, --sponsorblock       Ativar SponsorBlock (padrão: on)
  -S, --no-sponsorblock    Desativar SponsorBlock
  -l, --subtitles          Baixar legendas
  -L, --sub-langs LANGS    Idiomas: pt,en,es (padrão: pt,en)
  -t, --thumbnail          Baixar thumbnail
  -M, --metadata           Embed metadata + thumbnail
  -c, --concurrent N       Fragments paralelos 1-16 (padrão: 8)
  -T, --throttle RATE      Limite velocidade (ex: 5M, 10M)
  -p, --playlist-items ITENS  Ex: 1,3,5-10
  -d, --date-after DATE    Só após YYYYMMDD
  -w, --wait               Aguardar e baixar artifact automaticamente
  -o, --output-dir DIR     Pasta de saída (padrão: ~/Downloads/RichardGoLine)
  -r, --repo OWNER/REPO    Repo GitHub (padrão: repo atual)
  -h, --help               Esta ajuda

${YELLOW}Exemplos:${NC}
  gh-rgl "https://youtube.com/watch?v=dQw4w9WgXcQ"
  gh-rgl "URL" -m audio -a mp3
  gh-rgl "URL" -m 1080p -w
  gh-rgl "URL" -m custom -f "313+251" -w
  gh-rgl "URL" -m audio -w -o ~/Music

${YELLOW}Pré-requisitos:${NC}
  - gh CLI instalado e autenticado (gh auth login)
  - Repo com workflow .github/workflows/download.yml
EOF
}

# Parse args
URL=""
MODE="bestvideo+bestaudio (Máxima qualidade - MKV)"
AUDIO_FMT="opus"
AUDIO_QUAL="0"
CUSTOM_FMT=""
SPONSOR="true"
SUBTITLES="false"
SUB_LANGS="pt,en"
THUMB="false"
META="false"
CONCURRENT="8"
THROTTLE=""
PL_ITEMS=""
DATE_AFTER=""
WAIT=false
OUTPUT_DIR="$ARTIFACT_DIR"

while [[ $# -gt 0 ]]; do
  case $1 in
    -m|--mode) MODE="$2"; shift 2 ;;
    -f|--format) CUSTOM_FMT="$2"; MODE="formato-customizado (ID manual)"; shift 2 ;;
    -a|--audio-fmt) AUDIO_FMT="$2"; shift 2 ;;
    -q|--audio-quality) AUDIO_QUAL="$2"; shift 2 ;;
    -s|--sponsorblock) SPONSOR="true"; shift ;;
    -S|--no-sponsorblock) SPONSOR="false"; shift ;;
    -l|--subtitles) SUBTITLES="true"; shift ;;
    -L|--sub-langs) SUB_LANGS="$2"; shift 2 ;;
    -t|--thumbnail) THUMB="true"; shift ;;
    -M|--metadata) META="true"; shift ;;
    -c|--concurrent) CONCURRENT="$2"; shift 2 ;;
    -T|--throttle) THROTTLE="$2"; shift 2 ;;
    -p|--playlist-items) PL_ITEMS="$2"; shift 2 ;;
    -d|--date-after) DATE_AFTER="$2"; shift 2 ;;
    -w|--wait) WAIT=true; shift ;;
    -o|--output-dir) OUTPUT_DIR="$2"; shift 2 ;;
    -r|--repo) REPO="$2"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) URL="$1"; shift ;;
  esac
done

# Validações
if [[ -z "$URL" ]]; then
  err "URL obrigatória"
  usage
  exit 1
fi

if [[ ! "$URL" =~ ^https?:// ]]; then
  err "URL inválida: $URL"
  exit 1
fi

if [[ -z "$REPO" ]]; then
  err "Repo não detectado. Use -r OWNER/REPO ou rode dentro de um repo git"
  exit 1
fi

# Verifica gh
if ! command -v gh &>/dev/null; then
  err "gh CLI não instalado. Instale: https://cli.github.com/"
  exit 1
fi

if ! gh auth status &>/dev/null; then
  err "gh não autenticado. Rode: gh auth login"
  exit 1
fi

# Mapeia mode amigável -> valor do workflow
case "$MODE" in
  best|"bestvideo+bestaudio"*) MODE="bestvideo+bestaudio (Máxima qualidade - MKV)" ;;
  audio|bestaudio) MODE="bestaudio (Apenas áudio - MP3/Opus/FLAC)" ;;
  video|bestvideo) MODE="bestvideo (Apenas vídeo - sem áudio)" ;;
  1080p) MODE="1080p (Full HD - MP4)" ;;
  720p) MODE="720p (HD - MP4)" ;;
  4k|2160p) MODE="4k (2160p - MKV)" ;;
  custom|"formato-customizado"*) MODE="formato-customizado (ID manual)" ;;
esac

log "Iniciando download no GitHub Actions..."
echo "  Repo: $REPO"
echo "  URL: $URL"
echo "  Modo: $MODE"
echo "  Audio: $AUDIO_FMT q$AUDIO_QUAL"
echo "  SponsorBlock: $SPONSOR"
echo "  Legendas: $SUBTITLES ($SUB_LANGS)"
echo "  Concurrent: $CONCURRENT"
[[ -n "$THROTTLE" ]] && echo "  Throttle: $THROTTLE"
echo ""

# Trigger workflow
log "Disparando workflow..."
RUN_OUTPUT=$(gh workflow run "$WORKFLOW" -R "$REPO" \
  -f url="$URL" \
  -f mode="$MODE" \
  -f audio_format="$AUDIO_FMT" \
  -f audio_quality="$AUDIO_QUAL" \
  -f custom_format="$CUSTOM_FMT" \
  -f sponsorblock="$SPONSOR" \
  -f subtitles="$SUBTITLES" \
  -f sub_langs="$SUB_LANGS" \
  -f thumbnail="$THUMB" \
  -f metadata="$META" \
  -f concurrent="$CONCURRENT" \
  -f throttle="$THROTTLE" \
  -f playlist_items="$PL_ITEMS" \
  -f date_after="$DATE_AFTER" 2>&1)

if [[ $? -ne 0 ]]; then
  err "Falha ao disparar workflow:"
  echo "$RUN_OUTPUT"
  exit 1
fi

ok "Workflow disparado!"

# Pega run ID
log "Aguardando run aparecer..."
sleep 5

RUN_ID=$(gh run list -R "$REPO" --workflow="$WORKFLOW" --limit=1 --json databaseId -q '.[0].databaseId' 2>/dev/null)

if [[ -z "$RUN_ID" || "$RUN_ID" == "null" ]]; then
  warn "Não conseguiu pegar Run ID automaticamente"
  echo "Verifique em: https://github.com/$REPO/actions"
  exit 0
fi

log "Run ID: $RUN_ID"
echo "Acompanhe: https://github.com/$REPO/actions/runs/$RUN_ID"

if [[ "$WAIT" == "true" ]]; then
  log "Aguardando conclusão (pode demorar)..."
  echo ""
  
  while true; do
    STATUS=$(gh run view "$RUN_ID" -R "$REPO" --json conclusion -q '.conclusion' 2>/dev/null)
    JOB_STATUS=$(gh run view "$RUN_ID" -R "$REPO" --json jobs -q '.jobs[].conclusion' 2>/dev/null | head -1)
    
    case "$STATUS" in
      success)
        ok "Download concluído com sucesso!"
        break
        ;;
      failure|cancelled|timed_out)
        err "Falhou: $STATUS"
        gh run view "$RUN_ID" -R "$REPO" --log-failed 2>/dev/null | tail -30
        exit 1
        ;;
      *)
        # Mostra progresso do job
        PROGRESS=$(gh run view "$RUN_ID" -R "$REPO" --log 2>/dev/null | grep -E '(download|\[download\]|MERGE|ExtractAudio)' | tail -1)
        if [[ -n "$PROGRESS" ]]; then
          echo -ne "\r${CYAN}[progress]${NC} $PROGRESS                    "
        else
          echo -ne "\r${YELLOW}[aguardando]${NC} Status: $STATUS / Job: $JOB_STATUS                    "
        fi
        sleep 15
        ;;
    esac
  done
  
  echo ""
  log "Baixando artifact..."
  mkdir -p "$OUTPUT_DIR"
  
  if gh run download "$RUN_ID" -R "$REPO" --dir "$OUTPUT_DIR" 2>/dev/null; then
    ok "Arquivos salvos em: $OUTPUT_DIR"
    ls -lh "$OUTPUT_DIR"
  else
    warn "Falha ao baixar artifact. Tente manual:"
    echo "  gh run download $RUN_ID -R $REPO --dir $OUTPUT_DIR"
  fi
else
  echo ""
  echo "${YELLOW}Para baixar quando pronto:${NC}"
  echo "  gh run download $RUN_ID -R $REPO --dir $OUTPUT_DIR"
  echo ""
  echo "${YELLOW}Para acompanhar:${NC}"
  echo "  gh run watch $RUN_ID -R $REPO"
  echo "  # ou web: https://github.com/$REPO/actions/runs/$RUN_ID"
fi